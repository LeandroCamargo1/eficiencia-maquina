rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      // Próprio usuário tem acesso total
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Professor vinculado pode ler e atualizar dados do aluno
      // (necessário para: buscar descritores faciais, atualizar progressão de faixa)
      allow read, update: if request.auth != null
        && resource.data.linkedTeacherId == request.auth.uid;

      // Sub-coleção: check-ins
      match /checkins/{checkinId} {
        // Próprio aluno acessa seus check-ins
        allow read, write: if request.auth != null && request.auth.uid == userId;
        // Professor vinculado pode registrar check-in do aluno
        allow write: if request.auth != null
          && get(/databases/$(database)/documents/users/$(userId)).data.linkedTeacherId == request.auth.uid;
      }

      // Sub-coleção: solicitações de check-in (na coleção do professor)
      match /checkinRequests/{requestId} {
        // Professor gerencia suas próprias solicitações
        allow read, write: if request.auth != null && request.auth.uid == userId;
        // Qualquer aluno autenticado pode criar solicitação para um professor
        allow create: if request.auth != null;
      }
    }

    // Bloquear tudo que não foi explicitamente permitido
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
